# 本地环境
VITE_USER_NODE_ENV = development

# 公共基础路径
VITE_PUBLIC_PATH = /

# 路由模式
# Optional: hash | history
VITE_ROUTER_MODE = hash

# 打包时是否删除 console
VITE_DROP_CONSOLE = true

# 是否开启 VitePWA
VITE_PWA = false

# 开发环境接口地址
VITE_API_URL = /

# 后端服务地址（用于资源渲染等绝对路径）
VITE_SERVER_URL = http://127.0.0.1:9088

# 开发环境跨域代理，支持配置多个
VITE_PROXY = [["/base","http://127.0.0.1:9088/base"],["/menu","http://127.0.0.1:9088/menu"],["/user","http://127.0.0.1:9088/user"],["/agent","http://127.0.0.1:9088/agent"],["/chat","http://127.0.0.1:9088/chat"],["/document","http://127.0.0.1:9088/document"],["/llm-chat","http://127.0.0.1:9088/llm-chat"],["/role","http://127.0.0.1:9088/role"],["/api","http://127.0.0.1:9088/api"]]
